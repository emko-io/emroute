{
  "imports": {
    "@emkodev/emroute": "npm:@emkodev/emroute@1.12.4",
    "@emkodev/emroute/server": "npm:@emkodev/emroute@1.12.4/server",
    "@emkodev/emroute/runtime/universal/fs": "npm:@emkodev/emroute@1.12.4/runtime/universal/fs",
    "@emkodev/emkoma/render": "npm:@emkodev/emkoma@^0.4.0/render",
    "esbuild": "npm:esbuild@^0.24.0",
    "@guide/": "./util/"
  },
  "tasks": {
    "dev": "deno run --config=deno.dev.json --allow-net --allow-read --allow-write --allow-env --allow-run server.ts"
  },
  "deploy": {
    "org": "emkodev",
    "app": "emroute-guide"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "esnext", "dom", "dom.iterable", "dom.asynciterable"]
  }
}
