{
  "imports": {
    "@emkodev/emroute": "../src/index.ts",
    "@emkodev/emroute/server": "../server/emroute.server.ts",
    "@emkodev/emroute/runtime/universal/fs": "../runtime/universal/fs/universal-fs.runtime.ts",
    "@emkodev/emkoma/render": "../../emkoma/dist/render.js"
  },
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-env server.ts"
  },
  "deploy": {
    "org": "emkodev",
    "app": "emroute-guide",
    "runtime": {
      "type": "dynamic",
      "entrypoint": "server.ts"
    }
  },
  "compilerOptions": {
    "lib": ["deno.ns", "esnext", "dom", "dom.iterable", "dom.asynciterable"]
  }
}



